rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to check user role
    function hasRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // USER PROFILES: Users can only read/write their own profiles
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // QUEUES & CROWD DATA
    match /queues/{queueId} {
      allow read: if isAuth();
      allow write: if isAuth() && (hasRole('admin') || hasRole('staff'));
    }

    // TASKS: Attendees can't see staff tasks
    match /tasks/{taskId} {
      allow read, write: if isAuth() && (hasRole('admin') || hasRole('staff'));
    }

    // MESSAGES: Only read/write if part of the channel
    match /messages/{msgId} {
      allow read: if isAuth() && (
        resource.data.channel == 'public' || 
        (resource.data.channel == 'staff' && (hasRole('staff') || hasRole('admin')))
      );
      allow create: if isAuth() && (
        request.resource.data.channel == 'public' ||
        (request.resource.data.channel == 'staff' && (hasRole('staff') || hasRole('admin')))
      );
    }
    
    // ANALYTICS: Read only for admins
    match /venueflow_analytics/{docId} {
      allow read: if isAuth() && hasRole('admin');
      allow write: if false; // Only written via BigQuery/Cloud Functions
    }

    // RATELIMITS: Internal use only
    match /rateLimits/{userId} {
      allow read: if request.auth.uid == userId;
      allow write: if false; // Only written by Cloud Functions
    }
  }
}
