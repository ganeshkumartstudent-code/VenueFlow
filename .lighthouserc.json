{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--headless=new --no-sandbox",
        "budgets": [
          {
            "path": "/*",
            "resourceSizes": [
              {
                "resourceType": "script",
                "budget": 350
              },
              {
                "resourceType": "total",
                "budget": 1600
              }
            ],
            "resourceCounts": [
              {
                "resourceType": "third-party",
                "budget": 25
              }
            ]
          }
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "resource-summary:script:size": [
          "warn",
          {
            "maxNumericValue": 350000
          }
        ],
        "resource-summary:total:size": [
          "warn",
          {
            "maxNumericValue": 1600000
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
